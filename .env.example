# DATABASE - Railway PostgreSQL
# Ambil dari Railway dashboard > PostgreSQL service > Connect
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# JWT Secret - ganti dengan string random panjang
JWT_SECRET="sihadir-secret-ganti-ini-dengan-random-string-panjang"

# App URL - ganti saat deploy ke Railway
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Notifikasi WhatsApp via Fonnte
# Daftar di https://fonnte.com
FONNTE_TOKEN=""

# Notifikasi Telegram Bot
# Buat bot via @BotFather
TELEGRAM_BOT_TOKEN=""
TELEGRAM_DEFAULT_CHAT_ID=""

# Upload foto (gunakan Railway Volume atau Cloudinary)
# Jika pakai Cloudinary:
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
